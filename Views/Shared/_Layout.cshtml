<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRM Demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        .navbar-brand {
            font-weight: bold;
        }

        .sidebar {
            background-color: #f8f9fa;
            min-height: 100vh;
            padding-top: 20px;
        }

        .nav-link {
            color: #333;
        }

            .nav-link:hover {
                background-color: #e9ecef;
                border-radius: 4px;
            }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2 sidebar">
                <h5 class="text-center mb-4">CRM System</h5>
                <nav class="nav flex-column">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a class="nav-link" asp-controller="Customers" asp-action="Index">
                        <i class="fas fa-users"></i> Customers
                    </a>
                    <a class="nav-link" asp-controller="Opportunities" asp-action="Index">
                        <i class="fas fa-chart-line"></i> Opportunities
                    </a>
                    <a class="nav-link" asp-controller="Opportunities" asp-action="Pipeline">
                        <i class="fas fa-columns"></i> Pipeline
                    </a>
                </nav>
            </div>

            <!-- Main Content -->
            <div class="col-md-10">
                <main role="main" class="pb-3">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>