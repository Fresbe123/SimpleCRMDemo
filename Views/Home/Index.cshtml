@using CRMDemo.Models
@{
    ViewData["Title"] = "Dashboard";
    var recentOpps = ViewBag.RecentOpportunities as List<Opportunity>;
}

<div class="container mt-4">
    <h1 class="mb-4">Dashboard</h1>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Customers</h5>
                    <h2 class="card-text">@ViewBag.CustomerCount</h2>
                    <a asp-controller="Customers" asp-action="Index" class="text-white">View Details →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Total Opportunities</h5>
                    <h2 class="card-text">@ViewBag.OpportunityCount</h2>
                    <a asp-controller="Opportunities" asp-action="Index" class="text-white">View Details →</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Pipeline Value</h5>
                    <h2 class="card-text">@(((double)(ViewBag.PipelineValue ?? 0.0)).ToString("C"))</h2>
                    <a asp-controller="Opportunities" asp-action="Pipeline" class="text-white">View Pipeline →</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-controller="Customers" asp-action="Create" class="btn btn-primary">
                            <i class="fas fa-user-plus"></i> Add New Customer
                        </a>
                        <a asp-controller="Opportunities" asp-action="Create" class="btn btn-success">
                            <i class="fas fa-chart-line"></i> Create Opportunity
                        </a>
                        <a asp-controller="Opportunities" asp-action="Pipeline" class="btn btn-info">
                            <i class="fas fa-columns"></i> View Pipeline
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Recent Opportunities</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group">
                        @if (recentOpps != null)
                        {
                            foreach (var opp in recentOpps)
                            {
                                <li class="list-group-item">
                                    <strong>@opp.Title</strong> - @opp.Value.ToString("C")
                                    <br />
                                    <small>Customer: @opp.Customer?.Name</small>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>